rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isSelf(uid) { return isAuth() && request.auth.uid == uid; }
    function isGroupMember(groupId) {
      return isAuth() &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    match /users/{uid} {
      // Display info (name, photo, UPI ID) is readable by any signed-in user
      // so group members can render each other.
      allow read: if isAuth();
      allow create, update: if isSelf(uid);
      allow delete: if false;

      match /personalExpenses/{expenseId} {
        allow read, write: if isSelf(uid);
      }
    }

    match /groups/{groupId} {
      allow read: if isGroupMember(groupId);
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;
      // Members can update (rename, totals); joining via invite code also
      // needs update by a not-yet-member, restricted to membership fields.
      allow update: if isGroupMember(groupId)
        || (isAuth()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['memberUids', 'members', 'updatedAt'])
            && request.auth.uid in request.resource.data.memberUids);
      allow delete: if isAuth() && resource.data.createdBy == request.auth.uid;

      match /expenses/{expenseId} {
        allow read, create: if isGroupMember(groupId);
        allow update, delete: if isGroupMember(groupId);
      }

      match /settlements/{settlementId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId)
          && request.resource.data.createdBy == request.auth.uid;
        // Settlements are an immutable ledger.
        allow update, delete: if false;
      }
    }

    match /inviteCodes/{code} {
      // Any signed-in user can look up a code to join its group.
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if false;
      allow delete: if isAuth() && resource.data.createdBy == request.auth.uid;
    }
  }
}
